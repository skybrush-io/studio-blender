from __future__ import annotations

from collections.abc import MutableSequence, Sequence
from typing import Literal, TypeAlias, TypeVar, overload

RotationOrder: TypeAlias = Literal["XYZ", "XZY", "YXZ", "YZX", "ZXY", "ZYX"]

T = TypeVar("T")

class Euler(MutableSequence[float]):
    def __init__(self, angles: tuple[float, float, float], order: RotationOrder, /): ...

class Matrix:
    @classmethod
    def Identity(cls, size: int): ...
    @classmethod
    def Rotation(cls, angle: float, size: int, axis: str | Vector): ...
    @classmethod
    def Translation(cls, vector: Vector): ...
    def __init__(self, rows: Sequence[Sequence[float]] = ()): ...
    @overload
    def inverted(self) -> Matrix: ...
    @overload
    def inverted(self, fallback: T, /) -> Matrix | T: ...
    @property
    def translation(self) -> Vector: ...
    def to_3x3(self) -> Matrix: ...
    def to_quaternion(self) -> Quaternion: ...
    def to_euler(
        self, order: RotationOrder = "XYZ", euler_compat: Euler | None = None
    ) -> Euler: ...
    @overload
    def __matmul__(self, other: Matrix) -> Matrix: ...
    @overload
    def __matmul__(self, other: Vector) -> Vector: ...

class Quaternion(MutableSequence[float]):
    def __init__(self, values: Sequence[float]): ...
    @property
    def w(self) -> float: ...
    @property
    def x(self) -> float: ...
    @property
    def y(self) -> float: ...
    @property
    def z(self) -> float: ...

class Vector(MutableSequence[float]):
    def __init__(self, seq: Sequence[float]): ...
    @property
    def w(self) -> float: ...
    @property
    def x(self) -> float: ...
    @property
    def y(self) -> float: ...
    @property
    def z(self) -> float: ...
